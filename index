const total = properties.length;

function median(arr) {
  const s = [...arr].sort((a,b) => a-b);
  const mid = Math.floor(s.length / 2);
  return s.length % 2 !== 0 ? s[mid] : (s[mid-1] + s[mid]) / 2;
}
function fmtRM(n) {
  if (n == null) return '—';
  if (n >= 1000000) return 'RM ' + (n/1000000).toFixed(2) + 'M';
  return 'RM ' + Math.round(n).toLocaleString('en-US');
}
function fmtRMFull(n) {
  return n == null ? '—' : 'RM ' + Math.round(n).toLocaleString('en-US');
}

const now = new Date();
document.getElementById('updatedStamp').textContent = 'Last updated ' + now.toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'});
document.getElementById('panelTime').textContent = now.toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'});

// ============ derived aggregates ============
const prices = properties.map(p => p.price).filter(Boolean);
const areas = properties.map(p => p.area).filter(Boolean);
const unitPrices = properties.map(p => p.unit_price).filter(v => v && v > 50 && v < 20000);
const beds = properties.map(p => p.bed).filter(v => v && v <= 10);
const totalValue = prices.reduce((a,b) => a+b, 0);
const medPrice = median(prices);
const medArea = median(areas);
const medUnit = median(unitPrices);
const avgBed = beds.reduce((a,b)=>a+b,0) / beds.length;

const stateGroups = {};
properties.forEach(p => (stateGroups[p.state] = stateGroups[p.state] || []).push(p));
const stateStats = Object.entries(stateGroups)
  .map(([s, arr]) => ({ state: s, count: arr.length, med: median(arr.map(a => a.price)) }))
  .sort((a,b) => b.count - a.count);

const typeGroups = {};
properties.forEach(p => (typeGroups[p.type] = typeGroups[p.type] || []).push(p));
const typeStats = Object.entries(typeGroups)
  .map(([t, arr]) => ({ type: t, count: arr.length }))
  .sort((a,b) => b.count - a.count);

// collapse into top 3 + "Other"
const topTypes = typeStats.slice(0, 3);
const otherCount = typeStats.slice(3).reduce((a,t) => a + t.count, 0);
const donutData = [...topTypes, { type: 'Other', count: otherCount }];
const donutColors = ['#4BE3A0', '#34B8D9', '#9A6BF2', '#F4A24E'];

// ============ donut chart ============
const cx = 70, cy = 70, r = 52, strokeW = 16;
const circumference = 2 * Math.PI * r;
let offset = 0;
let donutSvg = `<circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="${strokeW}"/>`;
donutData.forEach((d, i) => {
  const frac = d.count / total;
  const len = frac * circumference;
  donutSvg += `<circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="${donutColors[i]}" stroke-width="${strokeW}"
    stroke-dasharray="${len.toFixed(1)} ${(circumference-len).toFixed(1)}" stroke-dashoffset="${(-offset).toFixed(1)}"
    stroke-linecap="butt" transform="rotate(-90 ${cx} ${cy})"/>`;
  offset += len;
});
donutSvg += `<text x="${cx}" y="${cy-4}" text-anchor="middle" font-family="Poppins, sans-serif" font-weight="700" font-size="20" fill="#EDF2FB">${total}</text>`;
donutSvg += `<text x="${cx}" y="${cy+14}" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" fill="#5A6785">LISTINGS</text>`;
document.getElementById('donut').innerHTML = donutSvg;

document.getElementById('donutLegend').innerHTML = donutData.map((d,i) => `
  <div class="legend-item">
    <span class="legend-dot" style="background:${donutColors[i]}"></span>
    ${d.type} <b>${d.count}</b>
  </div>
`).join('');

