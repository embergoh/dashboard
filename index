    <div class="card-label">Top state by volume</div>
    <div class="card-sub">${topState.count} listings · ${(topState.count/total*100).toFixed(0)}% of total</div>
    <div class="card-pill"><span class="pill"><span class="pdot"></span>Leading</span></div>
  </div>
`;

// ============ metric cards (with range bars) ============
function rangeBar(min, max, val, unit) {
  const pct = Math.max(2, Math.min(98, ((val - min) / (max - min)) * 100));
  return `
    <div class="range-bar">
      <div class="range-track"><div class="range-fill" style="width:${pct}%"></div><div class="range-dot" style="left:${pct}%"></div></div>
      <div class="range-labels"><span>${min}${unit}</span><span>${max}${unit}</span></div>
    </div>`;
}

const unitMin = Math.round(Math.min(...unitPrices));
const unitMax = Math.round(Math.max(...unitPrices));
const areaMin = Math.round(Math.min(...areas));
const areaMax = Math.round(Math.max(...areas));
const bedMin = Math.min(...beds);
const bedMax = Math.max(...beds);

document.getElementById('metricCards').innerHTML = `
  <div class="card orange">
    <div class="icon-badge"><svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
    <div class="big-num">RM ${Math.round(medUnit).toLocaleString('en-US')}</div>
    <div class="card-label">Median RM / m²</div>
    ${rangeBar(unitMin, unitMax, medUnit, '')}
    <div class="card-pill"><span class="pill"><span class="pdot"></span>Normal</span></div>
  </div>
  <div class="card teal">
