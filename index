<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Malaysia Property Market — Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg: #0A1220;
    --panel: #10192C;
    --panel-2: #131F36;
    --border: rgba(255,255,255,0.07);
    --text: #EDF2FB;
    --text-dim: #94A2C0;
    --text-faint: #5A6785;

    --green-a: #22C68B; --green-b: #0C6E4C;
    --blue-a: #34B8D9;  --blue-b: #13617E;
    --purple-a: #9A6BF2; --purple-b: #4C2A93;
    --orange-a: #F4A24E; --orange-b: #B4501C;
    --teal-a: #34D8C8;  --teal-b: #0E7E77;
    --royal-a: #5C93F7; --royal-b: #1F4FAE;

    --pill-green-bg: rgba(50,220,140,0.16);
    --pill-green-fg: #4BE3A0;
    --pill-amber-bg: rgba(255,180,70,0.16);
    --pill-amber-fg: #FFC15E;
  }

  * { box-sizing: border-box; }
  html { background: var(--bg); }

  body {
    margin: 0;
    background:
      radial-gradient(900px 500px at 75% -8%, rgba(90,110,240,0.14) 0%, transparent 60%),
      radial-gradient(700px 400px at 10% 0%, rgba(52,184,217,0.08) 0%, transparent 55%),
      var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  .shell {
    display: grid;
    grid-template-columns: 76px 1fr;
    min-height: 100vh;
  }

  /* ---------- Sidebar ---------- */
  .sidebar {
    background: rgba(255,255,255,0.02);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 24px 0;
    gap: 28px;
  }
  .sidebar .logo {
    width: 36px; height: 36px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--royal-a), var(--purple-b));
    display: flex; align-items: center; justify-content: center;
    font-family: 'Poppins', sans-serif;
    font-weight: 700;
    font-size: 15px;
    color: white;
  }
  .sidebar nav {
    display: flex; flex-direction: column; gap: 6px;
    margin-top: 12px;
    flex: 1;
  }
  .sidebar .nav-item {
    width: 44px; height: 44px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    color: var(--text-faint);
    cursor: default;
  }
  .sidebar .nav-item svg { width: 19px; height: 19px; }
  .sidebar .nav-item.active {
    background: rgba(90,140,255,0.14);
    color: var(--royal-a);
  }

  /* ---------- Main ---------- */
  .main { padding: 26px 34px 60px; max-width: 1280px; }

  .topbar {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 30px;
  }
  .topbar .brand {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 15px;
    color: var(--text);
    white-space: nowrap;
  }
  .search-box {
    flex: 1;
    max-width: 420px;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .search-box svg { width: 15px; height: 15px; color: var(--text-faint); flex-shrink: 0; }
  .search-box input {
    background: none; border: none; outline: none;
    color: var(--text); font-size: 13px; width: 100%;
    font-family: 'Inter', sans-serif;
  }
  .search-box input::placeholder { color: var(--text-faint); }
  .topbar-spacer { flex: 1; }
  .topbar-icon {
    width: 38px; height: 38px;
    border-radius: 10px;
    background: var(--panel);
    border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    color: var(--text-dim);
  }
  .topbar-icon svg { width: 16px; height: 16px; }

  .page-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 26px;
    flex-wrap: wrap;
    gap: 12px;
  }
  .page-header h1 {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 22px;
    margin: 0 0 4px;
  }
  .page-header .sub { color: var(--text-faint); font-size: 12.5px; }
  .updated {
    font-size: 11.5px;
    color: var(--text-faint);
    text-align: right;
  }

  /* ---------- Layout grid ---------- */
  .grid-main {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 22px;
    align-items: start;
  }

  .panel {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 22px 22px 20px;
  }
  .panel-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 16px;
  }
  .panel-title {
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    font-size: 13.5px;
    letter-spacing: 0.02em;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .panel-title .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--royal-a); }
  .panel-time { font-size: 10.5px; color: var(--text-faint); }

  /* donut */
  .donut-wrap { display: flex; align-items: center; gap: 18px; margin-bottom: 18px; }
  .legend { display: flex; flex-direction: column; gap: 9px; font-size: 12px; }
  .legend-item { display: flex; align-items: center; gap: 8px; color: var(--text-dim); }
  .legend-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .legend-item b { color: var(--text); font-weight: 600; margin-left: auto; padding-left: 10px; }

  /* mini state table */
  .mini-table { width: 100%; border-collapse: collapse; margin-top: 4px; }
  .mini-table th {
    text-align: left;
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-faint);
    font-weight: 500;
    padding: 6px 8px;
    border-bottom: 1px solid var(--border);
  }
  .mini-table td {
    padding: 9px 8px;
    font-size: 12.5px;
    color: var(--text-dim);
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .mini-table td:first-child { color: var(--text); font-weight: 500; }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 9px;
    border-radius: 20px;
    font-size: 10.5px;
    font-weight: 600;
  }
  .pill.green { background: var(--pill-green-bg); color: var(--pill-green-fg); }
  .pill.amber { background: var(--pill-amber-bg); color: var(--pill-amber-fg); }
  .pill .pdot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; }

  .panel-footer {
    display: flex;
    gap: 24px;
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }
  .panel-footer .stat b {
    display: block;
    font-family: 'Poppins', sans-serif;
    font-size: 21px;
    font-weight: 700;
    color: var(--royal-a);
  }
  .panel-footer .stat span {
    font-size: 10.5px;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ---------- Card sections ---------- */
  .section-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Poppins', sans-serif;
    font-size: 12.5px;
    font-weight: 600;
    color: var(--text-dim);
    margin-bottom: 12px;
  }
  .section-label .dot { width: 6px; height: 6px; border-radius: 50%; }

  .card-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }
  .card {
    border-radius: 16px;
    padding: 18px 18px 16px;
    color: white;
    position: relative;
    overflow: hidden;
    min-height: 148px;
    display: flex;
    flex-direction: column;
  }
  .card::after {
    content: "";
    position: absolute;
    right: -30px; top: -30px;
    width: 110px; height: 110px;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
  }
  .card .icon-badge {
    width: 32px; height: 32px;
    border-radius: 9px;
    background: rgba(255,255,255,0.18);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 12px;
  }
  .card .icon-badge svg { width: 16px; height: 16px; }
  .card .big-num {
    font-family: 'Poppins', sans-serif;
    font-weight: 700;
    font-size: 25px;
    line-height: 1.1;
  }
  .card .card-label {
    font-size: 11.5px;
    opacity: 0.85;
    margin-top: 3px;
  }
  .card .card-sub {
    font-size: 11px;
    opacity: 0.75;
    margin-top: 10px;
  }
  .card .card-pill {
    margin-top: auto;
    align-self: flex-start;
    padding-top: 12px;
  }
  .card .card-pill .pill { background: rgba(255,255,255,0.2); color: white; }

  .card.green { background: linear-gradient(135deg, var(--green-a), var(--green-b)); }
  .card.blue { background: linear-gradient(135deg, var(--blue-a), var(--blue-b)); }
  .card.purple { background: linear-gradient(135deg, var(--purple-a), var(--purple-b)); }
  .card.orange { background: linear-gradient(135deg, var(--orange-a), var(--orange-b)); }
  .card.teal { background: linear-gradient(135deg, var(--teal-a), var(--teal-b)); }
  .card.royal { background: linear-gradient(135deg, var(--royal-a), var(--royal-b)); }

  /* range bar inside metric cards */
  .range-bar {
    margin-top: 12px;
    position: relative;
  }
  .range-track {
    height: 4px;
    background: rgba(255,255,255,0.25);
    border-radius: 3px;
    position: relative;
  }
  .range-fill {
    position: absolute; left: 0; top: 0; bottom: 0;
    background: white;
    border-radius: 3px;
  }
  .range-dot {
    position: absolute;
    top: 50%;
    width: 10px; height: 10px;
    background: white;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 0 3px rgba(255,255,255,0.25);
  }
  .range-labels {
    display: flex;
    justify-content: space-between;
    font-size: 9.5px;
    opacity: 0.7;
    margin-top: 6px;
  }

  /* ---------- Browse table (below) ---------- */
  .browse-panel { margin-top: 28px; }
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 18px;
  }
  .filters select, .filters input {
    background: var(--panel-2);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 12.5px;
    padding: 9px 13px;
    border-radius: 9px;
    outline: none;
  }
  .filters select:focus, .filters input:focus { border-color: var(--royal-a); }
  .filters input::placeholder { color: var(--text-faint); }

  .table-wrap { border-radius: 14px; overflow: hidden; border: 1px solid var(--border); }
  table.data { width: 100%; border-collapse: collapse; font-size: 12.8px; }
  table.data thead th {
    text-align: left;
    font-size: 10.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-faint);
    font-weight: 600;
    padding: 12px 14px;
    background: var(--panel-2);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  table.data tbody td {
    padding: 10px 14px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    color: var(--text-dim);
    white-space: nowrap;
    background: var(--panel);
  }
  table.data tbody tr:hover td { background: var(--panel-2); color: var(--text); }
  table.data td.price { color: var(--green-a); font-weight: 700; font-family: 'Poppins', sans-serif; }
  table.data td.type-tag { color: var(--blue-a); font-size: 11px; font-weight: 600; }

  .table-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 14px;
    font-size: 12px;
    color: var(--text-faint);
  }
  .pager { display: flex; gap: 8px; align-items: center; }
  .pager button {
    background: var(--panel-2);
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-size: 12px;
    padding: 7px 14px;
    cursor: pointer;
    border-radius: 8px;
  }
  .pager button:hover:not(:disabled) { border-color: var(--royal-a); color: var(--royal-a); }
  .pager button:disabled { opacity: 0.35; cursor: default; }

  footer {
    margin-top: 40px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
    font-size: 11px;
    color: var(--text-faint);
  }

  @media (max-width: 980px) {
    .shell { grid-template-columns: 1fr; }
    .sidebar { display: none; }
    .grid-main { grid-template-columns: 1fr; }
    .card-row { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .card-row { grid-template-columns: 1fr; }
  }
</style>
</head>
